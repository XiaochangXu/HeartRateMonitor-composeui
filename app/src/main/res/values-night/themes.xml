<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Compose 接管所有 UI 颜色（MaterialTheme.colorScheme）；
      本主题仅提供窗口级系统配色（statusBar / navigationBar / windowBackground）。
      父主题使用 framework 级 android:Theme.Material.NoActionBar（暗色变体），
      不再依赖 com.google.android.material:material 主题。
    -->
    <style name="Theme.HeartRateMonitorMobile" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
</resources>
